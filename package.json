{
  "name": "command-tracker",
  "displayName": "Command & Prompt Tracker",
  "publisher": "skdsam",
  "description": "Manage reusable commands and prompts with a premium native UI.",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "command-tracker-sidebar",
          "title": "Command Tracker",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "command-tracker-sidebar": [
        {
          "type": "webview",
          "id": "command-tracker-view",
          "name": "Commands & Prompts"
        }
      ]
    },
    "commands": [
      {
        "command": "command-tracker.addEntry",
        "title": "Add to Command Tracker"
      },
      {
        "command": "command-tracker.sync",
        "title": "Sync Commands (Git)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "16.x",
    "typescript": "^5.1.3",
    "eslint": "^8.41.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8"
  }
}
